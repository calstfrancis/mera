{
  "manifest_version": 3,
  "name": "Tab Cap",
  "version": "1.0.2",
  "description": "Set a hard limit on the number of tabs you can have open at once.",

  "browser_specific_settings": {
    "gecko": {
      "id": "tabcap@calstfrancis",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },

  "permissions": ["tabs", "storage", "notifications", "theme"],

  "background": {
    "scripts": ["background.js"]
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Cap",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "theme_icons": [
      {
        "light": "icons/icon-dark-16.png",
        "dark":  "icons/icon-light-16.png",
        "size":  16
      },
      {
        "light": "icons/icon-dark-32.png",
        "dark":  "icons/icon-light-32.png",
        "size":  32
      }
    ]
  },

  "icons": {
    "16": "icons/icon-dark-16.png",
    "32": "icons/icon-dark-32.png",
    "48": "icons/icon-dark-48.png",
    "96": "icons/icon-dark-96.png"
  },

  "options_ui": {
    "page": "popup.html",
    "open_in_tab": false
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+T"
      },
      "description": "Open Tab Cap"
    }
  }
}
